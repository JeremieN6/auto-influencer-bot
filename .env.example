# ================================================================
# .env — Variables d'environnement
# NE JAMAIS COMMIT CE FICHIER
# Copier ce fichier en .env et remplir les valeurs
# ================================================================

# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Telegram Bot (créer via @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID du compte qui reçoit les validations (obtenir via @userinfobot)
TELEGRAM_CHAT_ID=

# Meta Graph API (Instagram)
# Access Token long-lived (60 jours) depuis Meta for Developers
INSTAGRAM_ACCESS_TOKEN=
# ID du compte Instagram professionnel (pas le username, l'ID numérique)
INSTAGRAM_ACCOUNT_ID=

# ================================================================
# Kling AI Motion Control (workflow vidéo V3)
# Créer un compte sur https://klingai.com → API Keys
# ================================================================
KLINGAI_ACCESS_KEY=
KLINGAI_SECRET_KEY=
# Modèle disponible : kling-v3 | kling-v2.6
KLINGAI_MODEL=kling-v3

# ================================================================
# TikTok Content Posting API (workflow vidéo V3)
# https://developers.tiktok.com/doc/content-posting-api-get-started
# ================================================================
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
