# ================================================================
# .env — Variables d'environnement
# NE JAMAIS COMMIT CE FICHIER
# Copier ce fichier en .env et remplir les valeurs
# ================================================================

# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Telegram Bot (créer via @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID du compte qui reçoit les validations (obtenir via @userinfobot)
TELEGRAM_CHAT_ID=

# Meta Graph API (Instagram)
# Access Token long-lived (60 jours) depuis Meta for Developers
INSTAGRAM_ACCESS_TOKEN=
# ID du compte Instagram professionnel (pas le username, l'ID numérique)
INSTAGRAM_ACCOUNT_ID=
