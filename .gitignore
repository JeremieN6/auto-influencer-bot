# Environnement
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.venv/
venv/
env/
ENV/

# Outputs (images générées — transient)
outputs/*.jpg
outputs/*.jpeg
outputs/*.png
outputs/*.webp
outputs/*.mp4
outputs/*.mov
outputs/*.webm

# Logs
logs/*.log
logs/cron.log

# Données runtime (état généré automatiquement — NE PAS déployer via git)
# Ces fichiers sont propres à chaque environnement (local vs VPS)
data/history.json
data/pending_state.json
data/video_history.json

# Image de référence (ne pas commit — données sensibles/propriétaires)
data/ref_*.jpg
data/ref_*.jpeg
data/ref_*.png
data/ref_*.webp
data/ref_*.avif

# Vidéos locales (contenu du dossier — le dossier lui-même est visible)
# Le fichier .gitkeep maintient le dossier dans git
data/videos/*.mp4
data/videos/*.mov
data/videos/*.webm
data/videos/*.avi
data/videos/*.mkv
data/videos/*.flv
data/videos/*.mpeg
# Images extraites des vidéos (ne pas commit — données sensibles/propriétaires)
data/videos/*.jpg
data/videos/*.jpeg
data/videos/*.png
data/videos/*.webp

# Fichiers temporaire / de travail
/temp/
*.tmp

# System
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/settings.json
.idea/

# Playwright
playwright-report/
test-results/

#Prompt
PROMPTS/
prompts/

#Scripts de développement
scripts/

